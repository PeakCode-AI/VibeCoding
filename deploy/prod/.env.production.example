# 生产环境配置示例（占位值，可入库）
# 实际部署请复制为 .env.production 并填入真实值（.env.production 不入库）。

# ===== 对外访问 =====
PUBLIC_DOMAIN=www.vibeadmin.cn

# ===== 数据库（服务器同机宝塔 PG，容器经 host.docker.internal:5432 连接）=====
DB_USER=vibeadmin
DB_PASSWORD=<替换为真实数据库密码>
DB_NAME=vibeadmin

# ===== JWT（两后端必须一致，用于跨服务互认）=====
# 生成：openssl rand -hex 32
SECRET_KEY=<替换为 64 位随机 hex>

# ===== CORS（逗号分隔的前端来源）=====
CORS_ORIGINS=http://<服务器公网IP>,http://<服务器公网IP>:8082

# ===== 对象存储 MinIO（本编排会启动 MinIO 容器）=====
# 生成：openssl rand -hex 8 / openssl rand -hex 16
S3_ACCESS_KEY=<8 位随机>
S3_SECRET_KEY=<16 位随机>
S3_BUCKET=vibe-storage

# ===== AI 模型（可选，留空则对话走降级）=====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
VL_API_KEY=
VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VL_MODEL=qwen-vl-plus

# ===== 支付回调验签（可选，留空则拒绝匿名回调）=====
PAYMENT_NOTIFY_SECRET=
